import { useState, useEffect } from "react";
import { Card, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { 
  Sparkles, 
  Moon, 
  Sun, 
  Copy, 
  Trash2, 
  Settings, 
  Image as ImageIcon, 
  Type, 
  Palette,
  MessageSquare,
  Gift,
  Heart,
  Award,
  Church,
  Calendar,
  User
} from "lucide-react";

export default function FlyerPromptGenerator() {
  const [tab, setTab] = useState("chat");
  const [isDarkMode, setIsDarkMode] = useState(true);
  const [chatInput, setChatInput] = useState("");
  const [isParsing, setIsParsing] = useState(false);
  const [mode, setMode] = useState("Auto");
  const [strength, setStrength] = useState("Ultra");

  const [form, setForm] = useState({
    eventType: "Birthday",
    title: "",
    subtitle: "",
    primaryName: "",
    primaryRole: "Celebrant",
    secondaryName: "",
    secondaryRole: "Family Members",
    theme: "Modern Premium",
    primaryColor: "#FFD700",
    secondaryColor: "#000000",
    date: "",
    venue: "",
    contact: "",
    description: "",
    highlights: "",
    quote: "",
    footer: ""
  });

  const eventConfigs = {
    Birthday: {
      icon: <Gift className="w-4 h-4" />,
      title: "Birthday E-Card",
      roles: ["Celebrant", "Family/Friends", "Background"],
      keywords: ["festive", "balloons", "cake", "joyful portrait", "warm lighting"]
    },
    Anniversary: {
      icon: <Heart className="w-4 h-4" />,
      title: "Anniversary Celebration",
      roles: ["Couple", "Supporting Images", "Romantic Backdrop"],
      keywords: ["elegant", "romantic", "gold accents", "timeless", "soft bokeh"]
    },
    Dedication: {
      icon: <Church className="w-4 h-4" />,
      title: "Dedication / Baptism",
      roles: ["Subject", "Parents/Godparents", "Sanctuary"],
      keywords: ["serene", "spiritual", "white and gold", "ethereal lighting", "dove"]
    },
    Award: {
      icon: <Award className="w-4 h-4" />,
      title: "Awards & Recognition",
      roles: ["Awardee", "Presenter", "Stage/Audience"],
      keywords: ["grand", "cinematic", "spotlight", "high contrast", "prestige"]
    },
    Commemoration: {
      icon: <Calendar className="w-4 h-4" />,
      title: "Commemoration / Event",
      roles: ["Key Figure", "Participants", "Venue Layout"],
      keywords: ["professional", "monumental", "structured", "clean composition"]
    }
  };

  const handleChange = (key, value) => {
    setForm(prev => ({ ...prev, [key]: value }));
  };

  const toggleTheme = () => setIsDarkMode(!isDarkMode);

  // AI Parsing Logic
  const handleAIParse = () => {
    setIsParsing(true);
    setTimeout(() => {
      const input = chatInput.toLowerCase();
      const newForm = { ...form };

      // Simple keyword detection for event type
      if (input.includes("birthday") || input.includes("turning")) newForm.eventType = "Birthday";
      else if (input.includes("anniversary") || input.includes("married")) newForm.eventType = "Anniversary";
      else if (input.includes("baptism") || input.includes("dedication")) newForm.eventType = "Dedication";
      else if (input.includes("award") || input.includes("winner")) newForm.eventType = "Award";
      else if (input.includes("commemoration") || input.includes("memorial")) newForm.eventType = "Commemoration";

      // Detect Names (Capitalized words followed by 'is' or similar, simplified here)
      const names = chatInput.match(/[A-Z][a-z]+/g) || [];
      if (names.length > 0) newForm.primaryName = names[0];
      if (names.length > 1) newForm.secondaryName = names.slice(1).join(", ");

      // Detect Date patterns
      const dateMatch = chatInput.match(/\d{1,2}(st|nd|rd|th)?\s+(of\s+)?(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*/i);
      if (dateMatch) newForm.date = dateMatch[0];

      // Detect Colors
      const colors = ["gold", "silver", "black", "white", "blue", "red", "purple", "emerald", "royal"];
      const foundColors = colors.filter(c => input.includes(c));
      if (foundColors.length > 0) newForm.primaryColor = foundColors[0];
      if (foundColors.length > 1) newForm.secondaryColor = foundColors[1];

      // Description logic
      newForm.description = chatInput.length > 100 ? chatInput.substring(0, 200) + "..." : chatInput;

      setForm(newForm);
      setIsParsing(false);
      setTab("content");
    }, 1500);
  };

  const generatePrompt = () => {
    const config = eventConfigs[form.eventType] || eventConfigs.Birthday;
    const isBirthday = form.eventType === "Birthday";

    return `### MASTER DESIGN PROMPT: ${form.eventType.toUpperCase()} PREMIMUM FLYER ###

CONCEPT: A high-end, cinematic ${form.eventType} design with ${form.theme} aesthetics.

IMAGE COMPOSITION & ROLES:
- IMAGE 1 (PRIMARY): ${form.primaryName || "Main Subject"}. Role: ${config.roles[0]}. 
  *Instruction: Professional portrait, crystal clear facial features, ${config.keywords[3]}.*
- IMAGE 2 (SECONDARY): ${form.secondaryName || "Family/Supporting"}. Role: ${config.roles[1]}. 
  *Instruction: ${isBirthday ? "Group photo of family members or friends" : "Secondary subject"}, blended naturally with a lower opacity or depth of field.*
- IMAGE 3 (ENVIRONMENT): ${config.roles[2]}.
  *Instruction: Background environment reflecting ${form.venue || "a premium setting"}.*

TEXT LAYOUT:
- MAIN HEADING: "${form.title || "Celebrating Excellence"}" (Bold, stylish typography)
- SUB-HEADING: "${form.subtitle || "A Special Occasion"}"
- BODY: ${form.description}
- DETAILS: 
  * Date: ${form.date}
  * Venue: ${form.venue}
  * Contact: ${form.contact}

VISUAL STYLE:
- Theme: ${form.theme}
- Primary Palette: ${form.primaryColor}
- Secondary Palette: ${form.secondaryColor}
- Lighting: ${config.keywords[4]}, cinematic glow, soft rim lighting.
- Composition: Rule of thirds, ${config.keywords[0]}, subject-first hierarchy.

TECHNICAL SPECS:
- Mode: ${mode} Precision
- Quality: ${strength} Rendering (8K, photorealistic, intricate textures, ray-traced reflections).
- Style: ${config.keywords.join(", ")}.

FOOTER: ${form.footer}`;
  };

  const themeClasses = isDarkMode 
    ? "bg-[#0f172a] text-slate-100 selection:bg-indigo-500/30" 
    : "bg-slate-50 text-slate-900 selection:bg-indigo-200";

  const cardClasses = isDarkMode
    ? "bg-slate-900/50 border-slate-800 backdrop-blur-xl"
    : "bg-white border-slate-200 shadow-sm";

  return (
    <div className={`min-h-screen transition-colors duration-300 ${themeClasses} font-sans`}>
      {/* Header */}
      <header className="border-b border-slate-800/50 p-4 sticky top-0 z-50 backdrop-blur-md flex justify-between items-center">
        <div className="flex items-center gap-3">
          <div className="w-10 h-10 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg shadow-indigo-500/20">
            <Sparkles className="text-white w-6 h-6" />
          </div>
          <div>
            <h1 className="text-xl font-bold tracking-tight">GRAFIGEN <span className="text-indigo-400">STUDIO</span></h1>
            <p className="text-[10px] uppercase tracking-[0.2em] text-slate-400 font-semibold">Prompt Generator v2.0</p>
          </div>
        </div>
        <div className="flex items-center gap-2">
          <Button variant="ghost" size="icon" onClick={toggleTheme} className="rounded-full">
            {isDarkMode ? <Sun className="w-5 h-5" /> : <Moon className="w-5 h-5" />}
          </Button>
          <Button variant="outline" className="hidden md:flex gap-2 border-slate-700 bg-slate-800/50">
            <Settings className="w-4 h-4" />
            Manage Assets
          </Button>
        </div>
      </header>

      <main className="max-w-7xl mx-auto p-6 grid lg:grid-cols-[280px_1fr_400px] gap-8">
        
        {/* Navigation Sidebar */}
        <nav className="space-y-2">
          <p className="text-xs font-semibold text-slate-500 uppercase px-3 py-2">Workflow</p>
          {[
            { id: "chat", icon: <MessageSquare className="w-4 h-4" />, label: "AI Magic Input" },
            { id: "content", icon: <Type className="w-4 h-4" />, label: "Content Details" },
            { id: "style", icon: <Palette className="w-4 h-4" />, label: "Aesthetics" },
            { id: "images", icon: <ImageIcon className="w-4 h-4" />, label: "Image Roles" },
          ].map(item => (
            <button
              key={item.id}
              onClick={() => setTab(item.id)}
              className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 ${
                tab === item.id 
                  ? "bg-indigo-600 text-white shadow-lg shadow-indigo-600/20 translate-x-1" 
                  : "hover:bg-slate-800/50 text-slate-400"
              }`}
            >
              {item.icon}
              <span className="font-medium text-sm">{item.label}</span>
            </button>
          ))}

          <div className="pt-8 space-y-2">
            <p className="text-xs font-semibold text-slate-500 uppercase px-3 py-2">Event Type</p>
            {Object.entries(eventConfigs).map(([key, cfg]) => (
              <button
                key={key}
                onClick={() => handleChange('eventType', key)}
                className={`w-full flex items-center justify-between px-4 py-2 rounded-lg text-sm transition-all ${
                  form.eventType === key 
                    ? "text-indigo-400 bg-indigo-400/10" 
                    : "text-slate-500 hover:text-slate-300"
                }`}
              >
                <div className="flex items-center gap-2">
                  {cfg.icon}
                  {key}
                </div>
                {form.eventType === key && <div className="w-1 h-1 rounded-full bg-indigo-400" />}
              </button>
            ))}
          </div>
        </nav>

        {/* Workspace */}
        <div className="space-y-6">
          <Card className={`${cardClasses} p-6 border-0 shadow-2xl overflow-hidden relative`}>
            {/* Decoration */}
            <div className="absolute -top-24 -right-24 w-48 h-48 bg-indigo-600/10 blur-[100px] rounded-full" />
            <div className="absolute -bottom-24 -left-24 w-48 h-48 bg-purple-600/10 blur-[100px] rounded-full" />

            <CardContent className="p-0 space-y-6 relative z-10">
              
              {tab === "chat" && (
                <div className="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-500">
                  <div className="space-y-2">
                    <h2 className="text-2xl font-bold flex items-center gap-2">
                      <Sparkles className="w-6 h-6 text-indigo-400" />
                      AI Magic Input
                    </h2>
                    <p className="text-slate-400 text-sm">Type everything you know about the event. I'll handle the formatting.</p>
                  </div>
                  <div className="relative">
                    <Textarea 
                      placeholder="e.g., Sarah is celebrating her 25th birthday on July 14th at the Grand Plaza. The theme is Royal Gold and Black. She wants a family photo included..."
                      className="min-h-[250px] bg-slate-950/50 border-slate-700 rounded-2xl p-6 focus:ring-2 focus:ring-indigo-500 transition-all text-lg leading-relaxed"
                      value={chatInput}
                      onChange={(e) => setChatInput(e.target.value)}
                    />
                    <Button 
                      className="absolute bottom-4 right-4 bg-indigo-600 hover:bg-indigo-500 rounded-xl px-6 py-6 shadow-xl"
                      disabled={!chatInput || isParsing}
                      onClick={handleAIParse}
                    >
                      {isParsing ? (
                        <div className="flex items-center gap-2">
                          <div className="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin" />
                          Analyzing...
                        </div>
                      ) : (
                        "Generate Magic"
                      )}
                    </Button>
                  </div>
                  <div className="grid grid-cols-2 gap-4">
                    <div className="p-4 rounded-xl bg-slate-800/30 border border-slate-700/50">
                      <p className="text-[10px] text-slate-500 uppercase font-bold mb-1">PRO TIP</p>
                      <p className="text-xs text-slate-400">Include details about the colors, people, and vibes for better results.</p>
                    </div>
                    <div className="p-4 rounded-xl bg-slate-800/30 border border-slate-700/50">
                      <p className="text-[10px] text-slate-500 uppercase font-bold mb-1">INTELLEGENCE</p>
                      <p className="text-xs text-slate-400">I'll automatically switch the event type based on your text.</p>
                    </div>
                  </div>
                </div>
              )}

              {tab === "content" && (
                <div className="space-y-4 animate-in fade-in slide-in-from-right-4 duration-500">
                  <h2 className="text-2xl font-bold">Content Details</h2>
                  <div className="grid grid-cols-2 gap-4">
                    <div className="space-y-1">
                      <label className="text-xs text-slate-500 font-semibold ml-1">Main Title</label>
                      <Input value={form.title} placeholder="e.g. Diamond Jubilee" onChange={e => handleChange('title', e.target.value)} className="bg-slate-950/50 border-slate-700" />
                    </div>
                    <div className="space-y-1">
                      <label className="text-xs text-slate-500 font-semibold ml-1">Subtitle</label>
                      <Input value={form.subtitle} placeholder="e.g. A Night of Elegance" onChange={e => handleChange('subtitle', e.target.value)} className="bg-slate-950/50 border-slate-700" />
                    </div>
                  </div>
                  <div className="grid grid-cols-2 gap-4">
                    <div className="space-y-1">
                      <label className="text-xs text-slate-500 font-semibold ml-1">{eventConfigs[form.eventType].roles[0]} Name</label>
                      <Input value={form.primaryName} placeholder="Full Name" onChange={e => handleChange('primaryName', e.target.value)} className="bg-slate-950/50 border-slate-700" />
                    </div>
                    <div className="space-y-1">
                      <label className="text-xs text-slate-500 font-semibold ml-1">{eventConfigs[form.eventType].roles[1]} Info</label>
                      <Input value={form.secondaryName} placeholder="Names/Roles" onChange={e => handleChange('secondaryName', e.target.value)} className="bg-slate-950/50 border-slate-700" />
                    </div>
                  </div>
                  <div className="space-y-1">
                    <label className="text-xs text-slate-500 font-semibold ml-1">Date & Time</label>
                    <Input value={form.date} placeholder="e.g. 24th Oct | 4:00 PM" onChange={e => handleChange('date', e.target.value)} className="bg-slate-950/50 border-slate-700" />
                  </div>
                  <div className="space-y-1">
                    <label className="text-xs text-slate-500 font-semibold ml-1">Venue Address</label>
                    <Input value={form.venue} placeholder="Location details" onChange={e => handleChange('venue', e.target.value)} className="bg-slate-950/50 border-slate-700" />
                  </div>
                  <div className="space-y-1">
                    <label className="text-xs text-slate-500 font-semibold ml-1">Description / About</label>
                    <Textarea value={form.description} placeholder="Describe the vibe..." onChange={e => handleChange('description', e.target.value)} className="bg-slate-950/50 border-slate-700" />
                  </div>
                </div>
              )}

              {tab === "style" && (
                <div className="space-y-6 animate-in fade-in slide-in-from-right-4 duration-500">
                  <h2 className="text-2xl font-bold">Aesthetics</h2>
                  
                  <div className="grid grid-cols-2 gap-6">
                    <div className="space-y-2">
                      <label className="text-sm font-medium">Design Theme</label>
                      <select 
                        className="w-full bg-slate-950/50 border border-slate-700 rounded-lg p-2 focus:ring-2 focus:ring-indigo-500"
                        value={form.theme}
                        onChange={e => handleChange('theme', e.target.value)}
                      >
                        <option>Modern Premium</option>
                        <option>Minimalist Gold</option>
                        <option>Vibrant Celebration</option>
                        <option>Spiritual Ethereal</option>
                        <option>Corporate Sleek</option>
                      </select>
                    </div>
                    <div className="space-y-2">
                      <label className="text-sm font-medium">Prompt Strength</label>
                      <div className="flex bg-slate-950/50 p-1 rounded-lg border border-slate-700">
                        {["Basic", "Ultra"].map(s => (
                          <button
                            key={s}
                            onClick={() => setStrength(s)}
                            className={`flex-1 py-1 text-xs font-bold rounded-md transition-all ${
                              strength === s ? "bg-indigo-600 text-white shadow" : "text-slate-500 hover:text-slate-300"
                            }`}
                          >
                            {s}
                          </button>
                        ))}
                      </div>
                    </div>
                  </div>

                  <div className="space-y-3">
                    <label className="text-sm font-medium">Brand Colors</label>
                    <div className="flex gap-4">
                      <div className="flex-1 space-y-1">
                        <Input value={form.primaryColor} onChange={e => handleChange('primaryColor', e.target.value)} placeholder="Primary Color" className="bg-slate-950/50 border-slate-700" />
                        <div className="h-2 rounded-full" style={{ backgroundColor: form.primaryColor || '#6366f1' }} />
                      </div>
                      <div className="flex-1 space-y-1">
                        <Input value={form.secondaryColor} onChange={e => handleChange('secondaryColor', e.target.value)} placeholder="Secondary Color" className="bg-slate-950/50 border-slate-700" />
                        <div className="h-2 rounded-full" style={{ backgroundColor: form.secondaryColor || '#000000' }} />
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {tab === "images" && (
                <div className="space-y-6 animate-in fade-in slide-in-from-right-4 duration-500">
                  <h2 className="text-2xl font-bold">Image Role Manager</h2>
                  <p className="text-slate-400 text-sm">Assign roles to your photos to help the AI place them correctly.</p>
                  
                  <div className="space-y-4">
                    {eventConfigs[form.eventType].roles.map((role, idx) => (
                      <div key={idx} className="flex items-center gap-4 p-4 rounded-2xl bg-indigo-500/5 border border-indigo-500/20">
                        <div className="w-12 h-12 rounded-xl bg-indigo-600 flex items-center justify-center text-xl font-bold">
                          {idx + 1}
                        </div>
                        <div>
                          <p className="font-bold text-indigo-400 uppercase text-[10px] tracking-wider">Position {idx + 1}</p>
                          <p className="text-lg font-medium">{role}</p>
                        </div>
                        <div className="ml-auto flex gap-2">
                          <Button size="sm" variant="ghost" className="text-slate-500"><User className="w-4 h-4" /></Button>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}

            </CardContent>
          </Card>

          {/* Action Footer */}
          <div className="flex justify-between items-center p-4 rounded-2xl bg-indigo-600/5 border border-indigo-600/10">
            <div className="flex items-center gap-3">
              <div className="w-2 h-2 rounded-full bg-green-500 animate-pulse" />
              <p className="text-xs text-slate-400 font-medium">Live Prompt Sync Active</p>
            </div>
            <div className="flex gap-2">
              <Button variant="ghost" className="text-red-400 hover:text-red-300 hover:bg-red-400/10" onClick={() => setForm({ ...form, title: "", subtitle: "", primaryName: "", secondaryName: "", description: "" })}>
                <Trash2 className="w-4 h-4" />
              </Button>
            </div>
          </div>
        </div>

        {/* Prompt Preview */}
        <div className="space-y-6">
          <Card className={`${cardClasses} p-6 border-0 shadow-2xl h-[calc(100vh-140px)] flex flex-col sticky top-24`}>
            <div className="flex items-center justify-between mb-4">
              <h2 className="font-bold flex items-center gap-2">
                <Sparkles className="w-4 h-4 text-indigo-400" />
                Prompt Preview
              </h2>
              <div className="text-[10px] font-bold px-2 py-1 bg-slate-800 rounded text-slate-400">READY</div>
            </div>
            <div className="flex-1 relative group">
              <Textarea 
                value={generatePrompt()} 
                readOnly 
                className="h-full bg-slate-950/80 border-slate-800 rounded-xl p-4 text-[13px] leading-relaxed font-mono text-indigo-100/80 resize-none scrollbar-hide" 
              />
              <div className="absolute inset-0 bg-indigo-600/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none rounded-xl" />
            </div>
            <div className="mt-4 space-y-3">
              <Button 
                onClick={() => {
                  navigator.clipboard.writeText(generatePrompt());
                  alert("Prompt copied to clipboard!");
                }}
                className="w-full bg-indigo-600 hover:bg-indigo-500 py-6 text-lg font-bold shadow-lg shadow-indigo-600/20"
              >
                <Copy className="w-5 h-5 mr-2" />
                Copy Master Prompt
              </Button>
              <p className="text-[10px] text-center text-slate-500">Paste this into Midjourney, DALL-E, or Stable Diffusion</p>
            </div>
          </Card>
        </div>

      </main>

      {/* Global CSS for custom animations and scrollbars */}
      <style>{`
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        
        @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slide-in-from-bottom { from { transform: translateY(10px); } to { transform: translateY(0); } }
        @keyframes slide-in-from-right { from { transform: translateX(10px); } to { transform: translateX(0); } }
        
        .animate-in {
          animation: fade-in 0.3s ease-out, slide-in-from-bottom 0.3s ease-out;
        }
      `}</style>
    </div>
  );
}
